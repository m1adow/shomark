{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=shomark;Username=postgres;Password=postgres;Include Error Detail=true"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "VideoProcessingTopic": "video-processing",
    "CompletionTopic": "video-processing-completed",
    "ConsumerGroupId": "api-group"
  },
  "Keycloak": {
    "Authority": "http://localhost:8180/realms/shomark",
    "Audience": "shomark-api",
    "RequireHttpsMetadata": false
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173", "http://localhost:4173", "http://localhost:3000" ]
  },
  "Minio": {
    "Endpoint": "localhost:9000",
    "AccessKey": "admin",
    "SecretKey": "password123",
    "Secure": false,
    "VideoBucket": "videos"
  }
}
