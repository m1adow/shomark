{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=shomark;Username=postgres;Password=postgres"
  },
  "Kafka": {
    "BootstrapServers": "kafka:29092",
    "VideoProcessingTopic": "video-processing",
    "CompletionTopic": "video-processing-completed",
    "PostPublishingTopic": "post-publishing",
    "ConsumerGroupId": "api-group"
  },
  "Keycloak": {
    "Authority": "http://keycloak:8080/realms/shomark",
    "Audience": "shomark-api",
    "RequireHttpsMetadata": false
  },
  "Cors": {
    "AllowedOrigins": [ "http://client" ]
  },
  "Frontend": {
    "BaseUrl": "http://client"
  },
  "Storage": {
    "Provider": "Minio",
    "VideoBucket": "videos"
  },
  "Minio": {
    "Endpoint": "minio:9000",
    "AccessKey": "admin",
    "SecretKey": "password123",
    "Secure": false
  },
  "AzureBlob": {
    "ConnectionString": "",
    "AccountName": "",
    "AccountKey": ""
  },
  "Video": {
    "AllowedContentTypes": [ "video/mp4", "video/quicktime" ],
    "MaxFileSizeBytes": 2147483648
  },
  "OAuth": {
    "Instagram": {
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "http://localhost:5000/api/oauth/Instagram/callback",
      "Scopes": "instagram_basic,instagram_content_publish,pages_show_list,pages_read_engagement"
    },
    "TikTok": {
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "http://localhost:5000/api/oauth/TikTok/callback",
      "Scopes": "user.info.basic,video.publish,video.upload"
    },
    "YouTube": {
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "http://localhost:5000/api/oauth/YouTube/callback",
      "Scopes": "https://www.googleapis.com/auth/youtube.upload https://www.googleapis.com/auth/youtube.readonly"
    },
    "X": {
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "http://localhost:5000/api/oauth/X/callback",
      "Scopes": "tweet.read tweet.write users.read offline.access"
    }
  }
}
