# ── PostgreSQL ──
POSTGRES_DB=shomark
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_PORT=5432

# ── Kafka ──
KAFKA_PORT=9092
KAFKA_UI_PORT=8080

# ── MinIO ──
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Keycloak ──
KC_DB_USERNAME=postgres
KC_DB_PASSWORD=
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=
KEYCLOAK_PORT=8180
KEYCLOAK_REALM=shomark
KEYCLOAK_CLIENT_ID=shomark-api

# ── Ollama ──
OLLAMA_MODEL=qwen3:30b-a3b

# ── API ──
API_PORT=5000
ASPNETCORE_ENVIRONMENT=Development

# ── Worker ──
WORKER_REPLICAS=3
